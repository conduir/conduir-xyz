# Conduir Protocol - Environment Configuration

# =============================================================================
# RPC Configuration
# =============================================================================

# Polkadot Testnet RPC URL
# Get a free RPC endpoint from https://chainlist.org/chain/1000
VITE_POLKADOT_RPC_URL=https://eth-rpc.polkadot.io

# Polkadot Testnet WebSocket URL (optional, for real-time updates)
VITE_POLKADOT_WS_URL=wss://eth-rpc.polkadot.io

# =============================================================================
# WalletConnect Configuration
# =============================================================================

# WalletConnect Project ID
# Get yours at https://cloud.walletconnect.com/
# This enables mobile wallet connection via WalletConnect
# Example: VITE_WALLET_CONNECT_PROJECT_ID=cb9875305ee3b6d452df9c3235492c0d
VITE_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# =============================================================================
# Application Configuration
# =============================================================================

# Polkadot Chain ID (defined in vite.config.ts as __POLKADOT_CHAIN_ID__)
# This value is used for network switching validation

# =============================================================================
# Development Settings
# =============================================================================

# Set to 'true' to disable HMR in AI Studio
DISABLE_HMR=false
